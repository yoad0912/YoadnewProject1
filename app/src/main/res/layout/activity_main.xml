<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:layoutDirection="rtl">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="MyFootballStats"
        app:titleTextColor="@android:color/white" />

    <ImageView
        android:id="@+id/imgPlayer"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_menu_camera"
        android:scaleType="centerCrop"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnChooseImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="בחר תמונה מהגלריה"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="תוצאה" />

    <EditText
        android:id="@+id/etGoals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="שערים"
        android:inputType="number"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etAssists"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="בישולים"
        android:inputType="number"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnAddMatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="הוסף משחק"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnGoToStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="מעבר לדף הסטטיסטיקות"
        android:layout_marginTop="12dp" />

</LinearLayout>